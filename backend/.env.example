# Adapter mode: mock | nocodb
DATA_ADAPTER=mock

# CORS origins separated by comma
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# NocoDB config (required when DATA_ADAPTER=nocodb)
NOCODB_BASE_URL=
NOCODB_API_TOKEN=
NOCODB_SONGS_ENDPOINT=
NOCODB_SONG_BOOKS_ENDPOINT=

# Optional alternative to endpoints
NOCODB_SONGS_TABLE_ID=
NOCODB_SONG_BOOKS_TABLE_ID=
