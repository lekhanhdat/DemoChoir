# CORS origins separated by comma
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional regex for dynamic origins (default allows Vercel preview/prod domains)
CORS_ALLOWED_ORIGIN_REGEX=^https://.*\.vercel\.app$

# NocoDB config (required)
NOCODB_BASE_URL=
NOCODB_API_TOKEN=

# Preferred: use table ids
NOCODB_SONGS_TABLE_ID=
NOCODB_SONG_BOOKS_TABLE_ID=

# Optional alternative to table ids
NOCODB_SONGS_ENDPOINT=
NOCODB_SONG_BOOKS_ENDPOINT=
